# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool, specifically when used with LiteIDE
*.out

# Dependency directories (remove the comment below to include it)
# vendor/

# Go workspace file
go.work
go.work.sum

# IDE specific files
.idea/
.vscode/
*.swp
*.swo

# OS specific files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
*.log

# Binary output directory
/bin/
/dist/

# Local environment variables
.env
.env.local

# Nix/direnv
.direnv/

**/.crush/**

/crush
/tmp/

manpages/
completions/crush.*sh
.prettierignore
.task
/web/test-results/
/test-results/

/web/dist/*
# Keep a committed placeholder so `//go:embed all:dist` (web/embed.go) resolves
# in CI without a Node build step — fixes build/lint/CodeQL on the fork. The
# real `npm run build` output stays ignored; only .gitkeep is tracked.
!/web/dist/.gitkeep
/web/node_modules/
/chroma_data/

# Fork-only scratchpad for delegating work to crush sub-agents
.tmp/

# Workspace-local Claude Code harness config (slash commands etc.)
# — generated by `crush claude-init`, not part of the source tree.
.claude/
