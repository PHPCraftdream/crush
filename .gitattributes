# Disable git's "LF will be replaced by CRLF" warning on Windows.
# Working text is LF-canonical (committed blobs use \n). On Windows
# `core.autocrlf=true` rewrites checkouts to CRLF and warns on every
# `git add` / `git diff`. The line below tells git to leave line
# endings alone — what is on disk is what gets committed.
* text=auto eol=lf

# Lockfiles and configs that some tools still write CRLF on Windows —
# normalised to LF by git on commit.
*.toml  text eol=lf
*.lock  text eol=lf
*.json  text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.md    text eol=lf

# Generated / minified web bundles — leave bytes alone.
*.min.js  binary
*.min.css binary

# Binary fixtures, snapshots, certificates — never touch.
*.png  binary
*.jpg  binary
*.pdf  binary
*.snap binary
*.der  binary

# Pre-existing project-specific rules (preserve).
*.golden                                  linguist-generated=true -text
.github/crush-schema.json                 linguist-generated=true
internal/agent/hyper/provider.json        linguist-generated=true
internal/agent/testdata/**/*.yaml -diff   linguist-generated=true
