{
  "name": "@phpcraftdream/crush",
  "version": "0.1.0",
  "description": "Unofficial npm distribution of crush — a fork of charmbracelet/crush. Installs a prebuilt, Go-free binary via per-platform optional packages. No download step at install time.",
  "license": "FSL-1.1-MIT",
  "author": "Charmbracelet, Inc. (upstream) and fork maintainers",
  "homepage": "https://github.com/charmbracelet/crush",
  "repository": {
    "type": "git",
    "url": "https://github.com/charmbracelet/crush.git"
  },
  "bugs": {
    "url": "https://github.com/charmbracelet/crush/issues"
  },
  "keywords": [
    "crush",
    "cli",
    "ai",
    "coding-assistant",
    "charm",
    "charmbracelet"
  ],
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "crush": "bin/crush.js"
  },
  "files": [
    "bin/crush.js"
  ],
  "optionalDependencies": {
    "@phpcraftdream/crush-linux-x64": "0.1.0",
    "@phpcraftdream/crush-linux-arm64": "0.1.0",
    "@phpcraftdream/crush-darwin-x64": "0.1.0",
    "@phpcraftdream/crush-darwin-arm64": "0.1.0",
    "@phpcraftdream/crush-win32-x64": "0.1.0"
  }
}
